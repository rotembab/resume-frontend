# GitHub profile to populate the Projects page and the Home stats.
# Used by src/config/env.ts; falls back to "Rotembab" if unset.
VITE_GITHUB_USERNAME=Rotembab

# EmailJS credentials for the contact form (see src/components/pages/contact-me/contact-form.component.tsx).
VITE_EMAILJS_SERVICE_ID=
VITE_REPLY_TEMPLATE_ID=
VITE_SEND_TO_ME_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
